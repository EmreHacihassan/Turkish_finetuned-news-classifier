# ============================================================================
# MODEL & TRAINING ARTIFACTS
# ============================================================================
# Core model files (train and save only in special cases, not in repo)
# Note: Only .json metadata files (config, tokenizer) are tracked
# Large weights (.bin, .safetensors) are excluded to avoid LFS bloat
model/*.bin
model/*.safetensors
model/*.msgpack
model/*.pt
model/*.pth

# Training checkpoints & logs
checkpoints/
logs/
*.log
training_logs/
wandb/

# Generated artifacts
*.png
eda_*.png
confusion_matrix.png
training_curves.png
*_curves.png

